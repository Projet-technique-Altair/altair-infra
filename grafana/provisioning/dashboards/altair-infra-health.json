    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Top Docker containers by CPU usage. Displayed with a shortened container ID extracted from the cgroup path.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "min": 0,
          "unit": "cores"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 5,
      "options": {
        "displayMode": "gradient",
        "namePlacement": "bottom",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": {}
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(5, label_replace(rate(container_cpu_usage_seconds_total{id=~\"/system.slice/docker-.*\\\\.scope\"}[1m]), \"container_short\", \"$1\", \"id\", \"/system.slice/docker-([a-f0-9]{12})[a-f0-9]*\\\\.scope\"))",
          "legendFormat": "{{container_short}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Top 5 CPU Containers",
      "type": "bargauge"
    },
